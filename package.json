{
  "name": "lazypr",
  "version": "1.5.1",
  "description": "Generate clean, consistent PRs from commits - powered by your favorite AI and your git history.",
  "keywords": [
    "ai",
    "cerebras",
    "cli",
    "git",
    "groq",
    "openai",
    "pull-request"
  ],
  "homepage": "https://lazypr.vercel.app",
  "bugs": {
    "url": "https://github.com/R4ULtv/lazypr/issues"
  },
  "license": "MIT",
  "author": "Raul Carini <contact@raulcarini.dev> (https://raulcarini.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/R4ULtv/lazypr.git"
  },
  "bin": {
    "lazypr": "dist/index.js",
    "lzp": "dist/lzp.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node --format esm --minify --external clipboardy",
    "postbuild": "echo '#!/usr/bin/env node\nimport(\"./index.js\");' > dist/lzp.js",
    "dev": "bun run index.ts",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxfmt",
    "check:fix": "oxfmt --check"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^2.0.34",
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/openai": "^3.0.31",
    "@clack/prompts": "^1.0.1",
    "ai": "^6.0.97",
    "clipboardy": "^5.3.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
